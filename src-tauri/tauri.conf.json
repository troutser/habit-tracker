{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "habit-widget",
  "version": "1.0.0",
  "identifier": "com.habitwidget.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Habit Widget",
        "width": 300,
        "height": 300,
	"decorations": false,
        "resizable": true,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": true,
	"center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
	 "enable": true,
	 "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png"
    ]
  },
  "plugins": {}
}
